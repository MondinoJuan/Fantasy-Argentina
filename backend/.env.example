### Backend runtime
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

### Database
# TODO(your-side): reemplazar con tu MySQL gestionado en producción (Railway/PlanetScale/Aiven/etc.)
DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/fantasy_argentina
DB_DEBUG=false
# En producción debe quedar false y usar migraciones.
DB_SYNC_SCHEMA=false

### Security
# TODO(your-side): generar un secreto largo y único (mínimo 24 chars) para producción.
AUTH_TOKEN_SECRET=change-this-before-production
AUTH_TOKEN_TTL_SECONDS=28800

### CORS (separar por coma)
# Ejemplo: https://tu-frontend.vercel.app,https://tu-dominio.com
CORS_ALLOWED_ORIGINS=http://localhost:4200

### Basic rate limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=500

### Existing integration variables
SUPERADMIN_SIGNUP_CODE=superadmin-code
# SPORTSAPIPRO_BASE_URL solo si necesitás endpoints legacy v1.
SPORTSAPIPRO_BASE_URL=https://v1.football.sportsapipro.com
SPORTSAPIPRO_BASE_URL_V2=
SPORTSAPIPRO_API_KEY1=
SPORTSAPIPRO_API_KEY2=
SPORTSAPIPRO_API_KEY3=
SPORTSAPIPRO_API_KEY4=
SPORTSAPIPRO_API_KEY5=
SPORTSAPIPRO_API_KEY6=
SPORTSAPIPRO_API_KEY7=
SPORTSAPIPRO_API_KEY8=
SPORTSAPIPRO_API_KEY9=
